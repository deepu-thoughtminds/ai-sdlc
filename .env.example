FREELLMAPI_BASE_URL=http://freellmapi:3001
FREELLMAPI_MODELS=auto
MAIN_MODEL=claude-3-5-haiku-20241022
JIRA_WEBHOOK_SECRET=changeme
LOG_LEVEL=INFO
BACKEND_URL=http://backend:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
ENCRYPTION_KEY=REPLACE_WITH_OUTPUT_OF_python3_-c_"from_cryptography.fernet_import_Fernet;print(Fernet.generate_key().decode())"
DATABASE_URL=sqlite:////app/data/app.db

# JWT auth for the /api endpoints (project CRUD, dashboard, tickets).
# There is NO login endpoint — generate one long-lived token and share it with
# the frontend, which sends it as: Authorization: Bearer <API_TOKEN>
#
# JWT_SECRET_KEY: signing secret — generate with: openssl rand -hex 32
# JWT_EXPIRE_MINUTES: default lifetime (min) for create_access_token (the static
#   token is minted with a 10-year expiry regardless).
# API_TOKEN: the generated token to hand the FE. Generate it after the stack is
#   up with: docker compose exec backend python generate_token.py
#   then paste the output here. (Not read by the backend for validation — any
#   token signed with JWT_SECRET_KEY is accepted — kept here as the shared copy.)
JWT_SECRET_KEY=REPLACE_WITH_OUTPUT_OF_openssl_rand_-hex_32
JWT_EXPIRE_MINUTES=720
API_TOKEN=GENERATE_WITH_docker_compose_exec_backend_python_generate_token.py
JIRA_ACCOUNT_EMAIL=your-email@company.com
# Jira instance credentials for mcp-atlassian (required for Jira operations)
# JIRA_URL: your Atlassian Cloud base URL, e.g. https://your-company.atlassian.net
# JIRA_API_TOKEN: generate at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_URL=https://your-company.atlassian.net
JIRA_API_TOKEN=your-atlassian-api-token
GITHUB_API_BASE=https://api.github.com


# freellmapi service encryption key (required)
# Generate: openssl rand -hex 32
FREELLMAPI_ENCRYPTION_KEY=

# freellmapi API key (generate via dashboard at http://localhost:3001 after first run)
FREELLMAPI_API_KEY=

# LLM Provider API keys (configure via freellmapi dashboard at http://localhost:3001)
# Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenRouter: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# MCP Atlassian service (mcp-atlassian Docker container)
# Internal URL used by the hermes container — do not change unless you move the service
MCP_ATLASSIAN_URL=http://mcp-atlassian:9000/mcp

# Hermes internal API base URL (backend → hermes /jira/* endpoints)
HERMES_BASE_URL=http://hermes:8001

# LiteLLM proxy auth token — used as ANTHROPIC_AUTH_TOKEN by the Claude Agent SDK.
# Must match general_settings.master_key in litellm/config.yaml.
# Do NOT set CLAUDE_API_KEY or ANTHROPIC_API_KEY — they would bypass the proxy.
LITELLM_MASTER_KEY=sk-litellm-local
